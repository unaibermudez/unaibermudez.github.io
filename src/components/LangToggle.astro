<button
	class="lang-toggle"
	id="lang-toggle"
	type="button"
	aria-label="Cambiar idioma"
	data-aria-es="Cambiar idioma"
	data-aria-en="Change language"
>
	<span class="label"></span>
</button>

<style is:global>
	/* Deliberately its own class (not shared with .theme-toggle): reusing that
	   class here made both buttons' `.label::before` rules collide at equal
	   specificity, so whichever landed later in the bundle won for both. */
	.lang-toggle {
		display: inline-block;
		padding: 6px 12px;
		border-radius: 999px;
		background: hsl(var(--theme-bg) / 0.82);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		color: hsl(var(--theme-text-muted));
		border: 1px solid var(--hairline);
		font-family: var(--font-mono);
		font-size: 11.5px;
		font-weight: 500;
		line-height: 1.4;
		cursor: pointer;
		box-shadow: 0 2px 10px rgba(24, 22, 17, 0.06);
		transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
	}
	.lang-toggle:hover {
		background: hsl(var(--theme-bg));
		border-color: hsl(var(--theme-accent) / 0.5);
		color: hsl(var(--theme-accent));
	}
	.lang-toggle:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
	}
	.lang-toggle .label {
		display: inline-block;
		min-width: 1.6em;
		text-align: left;
	}
	.lang-toggle .label::before {
		content: "EN";
	}
	html[data-lang="en"] .lang-toggle .label::before {
		content: "ES";
	}
</style>

<script>
	const root = document.documentElement;
	const btn = document.getElementById("lang-toggle") as HTMLButtonElement | null;
	if (btn) {
		// LangProvider.astro's `lang-change` listener applies the attribute,
		// `lang`, aria-label sync and localStorage persistence.
		btn.addEventListener("click", () => {
			const next = root.dataset.lang === "en" ? "es" : "en";
			document.dispatchEvent(new CustomEvent("lang-change", { detail: { lang: next } }));
		});
	}
</script>
