---
import { menuLinks, siteConfig } from "@/site-config";
import { withBase } from "@/utils/path";
import T from "@/components/T.astro";
import ThemeToggle from "../ThemeToggle.astro";
import LangToggle from "../LangToggle.astro";

const wordmark = "Unai Bermúdez";
const tagline = `${siteConfig.profile?.name ?? siteConfig.author} · ${siteConfig.profile?.jobTitle ?? ""}`;
---

<header class="site-nav" id="site-nav">
	<a class="nav-name" href={withBase("/")}>{wordmark}</a>

	<nav class="nav-center" aria-label="Sections" data-aria-es="Secciones" data-aria-en="Sections">
		{
			menuLinks.map((link) => (
				<a data-astro-prefetch href={withBase(link.path)}>
					<T k={link.titleKey} />
				</a>
			))
		}
	</nav>

	<div class="nav-right">
		<div class="nav-clock" aria-hidden="true">
			<span class="dot"></span>
			<span>BIO · <span id="nav-clock-time">--:--:--</span></span>
		</div>
		<ThemeToggle />
		<LangToggle />
		<button
			aria-expanded="false"
			aria-label="Abrir menú"
			data-aria-es="Abrir menú"
			data-aria-en="Open menu"
			class="burger"
			id="nav-burger"
			type="button"
		>
			<span></span><span></span>
		</button>
	</div>
</header>

<div class="m-menu" id="nav-mmenu">
	<div class="m-controls">
		<ThemeToggle />
		<LangToggle />
	</div>
	{
		menuLinks.map((link, i) => (
			<a data-astro-prefetch href={withBase(link.path)}>
				<span>
					<T k={link.titleKey} />
				</span>
				<span class="n">{String(i + 1).padStart(2, "0")}</span>
			</a>
		))
	}
	<div class="m-foot">
		<span>{tagline}</span>
		<span>Bilbao, ES</span>
	</div>
</div>

<style>
	.site-nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 500;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1.5rem;
		padding: 1rem max(var(--gutter), calc((100vw - var(--container)) / 2 + var(--gutter)));
		font-family: var(--font-mono);
		font-size: 0.74rem;
		letter-spacing: 0.04em;
		background: hsl(var(--theme-bg) / 0.72);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--hairline);
	}
	.nav-name {
		color: hsl(var(--theme-text));
		font-family: var(--font-serif);
		font-size: 1.05rem;
		font-style: italic;
		font-weight: 500;
	}
	.nav-center {
		grid-column: 2;
		display: flex;
		gap: 2rem;
		justify-self: center;
	}
	.nav-center a {
		color: hsl(var(--theme-text) / 0.8);
		position: relative;
		padding: 0.15rem 0;
		transition: color 0.2s ease;
	}
	.nav-center a:hover {
		color: hsl(var(--theme-text));
	}
	.nav-center a::after {
		content: "";
		position: absolute;
		left: 0;
		bottom: -2px;
		height: 1px;
		width: 100%;
		background: var(--klein);
		transform: scaleX(0);
		transform-origin: right;
		transition: transform 0.4s var(--ease);
	}
	.nav-center a:hover::after {
		transform: scaleX(1);
		transform-origin: left;
	}
	.nav-right {
		grid-column: 3;
		justify-self: end;
		display: flex;
		align-items: center;
		gap: 1.1rem;
	}
	.nav-clock {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		color: hsl(var(--theme-text) / 0.72);
	}
	.nav-clock .dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: #4ede78;
		animation: nav-blink 2.2s ease-in-out infinite;
	}
	@keyframes nav-blink {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.25;
		}
	}

	.burger {
		display: none;
		background: none;
		border: none;
		width: 34px;
		height: 34px;
		position: relative;
		padding: 0;
		cursor: pointer;
	}
	.burger span {
		position: absolute;
		left: 4px;
		right: 4px;
		height: 1.5px;
		background: hsl(var(--theme-text));
		transition:
			transform 0.4s var(--ease),
			opacity 0.3s;
	}
	.burger span:nth-child(1) {
		top: 12px;
	}
	.burger span:nth-child(2) {
		top: 20px;
	}
	.burger.open span:nth-child(1) {
		transform: translateY(4px) rotate(45deg);
	}
	.burger.open span:nth-child(2) {
		transform: translateY(-4px) rotate(-45deg);
	}

	@media (max-width: 760px) {
		.site-nav {
			padding: 1.1rem var(--gutter);
			grid-template-columns: auto 1fr auto;
			gap: 0.75rem;
		}
		.nav-center {
			display: none;
		}
		.nav-clock {
			display: none;
		}
		.nav-right :global(.theme-toggle),
		.nav-right :global(.lang-toggle) {
			display: none;
		}
		.burger {
			display: block;
		}
	}

	/* ---- mobile fullscreen menu ---- */
	.m-menu {
		position: fixed;
		inset: 0;
		z-index: 490;
		background: var(--paper);
		color: hsl(var(--theme-text));
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.3rem;
		padding: 0 var(--gutter);
		clip-path: inset(0 0 100% 0);
		transition: clip-path 0.6s var(--ease);
		visibility: hidden;
	}
	.m-menu.open {
		clip-path: inset(0 0 0 0);
		visibility: visible;
	}
	.m-controls {
		position: absolute;
		top: 4.8rem;
		right: var(--gutter);
		display: flex;
		align-items: center;
		gap: 0.6rem;
		opacity: 0;
		transform: translateY(-10px);
		transition:
			opacity 0.5s var(--ease),
			transform 0.5s var(--ease);
	}
	.m-menu.open .m-controls {
		opacity: 1;
		transform: translateY(0);
		transition-delay: 0.1s;
	}
	.m-menu a {
		font-family: var(--font-serif);
		font-weight: 300;
		font-style: italic;
		font-size: clamp(2.2rem, 11vw, 3.6rem);
		color: hsl(var(--theme-text));
		text-decoration: none;
		padding: 0.35rem 0;
		border-bottom: 1px solid var(--hairline);
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		opacity: 0;
		transform: translateY(26px);
		transition:
			opacity 0.5s var(--ease),
			transform 0.5s var(--ease);
	}
	.m-menu.open a {
		opacity: 1;
		transform: translateY(0);
	}
	.m-menu.open a:nth-child(1) {
		transition-delay: 0.12s;
	}
	.m-menu.open a:nth-child(2) {
		transition-delay: 0.18s;
	}
	.m-menu.open a:nth-child(3) {
		transition-delay: 0.24s;
	}
	.m-menu.open a:nth-child(4) {
		transition-delay: 0.3s;
	}
	.m-menu a .n {
		font-family: var(--font-mono);
		font-style: normal;
		font-size: 0.7rem;
		color: hsl(var(--theme-accent));
	}
	.m-foot {
		position: absolute;
		bottom: 2rem;
		left: var(--gutter);
		right: var(--gutter);
		font-family: var(--font-mono);
		font-size: 0.68rem;
		color: hsl(var(--theme-text) / 0.5);
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}
	@media (prefers-reduced-motion: reduce) {
		.m-menu,
		.m-menu a {
			transition: none;
		}
	}
</style>

<script>
	const burger = document.getElementById("nav-burger") as HTMLButtonElement | null;
	const mMenu = document.getElementById("nav-mmenu");
	if (burger && mMenu) {
		let scrollY = 0;
		const setMenu = (open: boolean) => {
			burger.classList.toggle("open", open);
			mMenu.classList.toggle("open", open);
			burger.setAttribute("aria-expanded", String(open));

			if (open) {
				scrollY = window.scrollY;
				document.body.style.top = `-${scrollY}px`;
				document.body.classList.add("menu-lock");
			} else {
				document.body.classList.remove("menu-lock");
				document.body.style.top = "";
				window.scrollTo(0, scrollY);
			}
		};
		burger.addEventListener("click", () => setMenu(!mMenu.classList.contains("open")));
		mMenu.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setMenu(false)));
	}

	const clockEl = document.getElementById("nav-clock-time");
	if (clockEl) {
		const tick = () => {
			const locale = document.documentElement.dataset.lang === "en" ? "en-GB" : "es-ES";
			clockEl.textContent = new Date().toLocaleTimeString(locale, {
				timeZone: "Europe/Madrid",
				hour12: false,
			});
		};
		tick();
		setInterval(tick, 1000);
	}
</script>

<style is:global>
	/* `overflow: hidden` alone doesn't reliably block touch-scroll/rubber-band
	   on mobile Safari, so the menu-open state also pins body to `position:
	   fixed` at the current scroll offset (set via JS below) and restores it
	   on close. */
	body.menu-lock {
		position: fixed;
		left: 0;
		right: 0;
		overflow: hidden;
	}
</style>
