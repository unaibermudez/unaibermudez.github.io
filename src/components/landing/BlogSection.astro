---
import { getPairDate, getPostPairs, sortPairsByDate } from "@/data/post";
import { formatRailDate } from "@/utils/date";
import { withBase } from "@/utils/path";
import Bilingual from "@/components/Bilingual.astro";
import T from "@/components/T.astro";

const allPairs = await getPostPairs();
const sorted = sortPairsByDate(allPairs);
const LIMIT = 4;
const recent = sorted.slice(0, LIMIT);
const archiveCount = allPairs.length;
---

<section class="section" id="blog">
	<div class="sec-head lr">
		<div>
			<p class="sec-index"><T k="blog.index" /></p>
			<h2 class="sec-title"><T k="blog.title" /></h2>
		</div>
		<p class="sec-note">
			<T k={archiveCount > 0 ? "blog.note" : "blog.noteEmpty"} />
		</p>
	</div>

	{
		recent.length === 0 ? (
			<div class="empty-state lr">
				<p>
					<T k="blog.emptyState" />
				</p>
			</div>
		) : (
			<div class="blog-list">
				{recent.map((pair, i) => {
					const date = getPairDate(pair);
					const hasEn = Boolean(pair.en);
					return (
						<a
							class:list={["blog-row", "lr", i === 0 && "lr-1", i === 1 && "lr-2", i >= 2 && "lr-3"]}
							data-astro-prefetch
							href={withBase(`/posts/${pair.slug}/`)}
						>
							<span class="blog-date">
								<time datetime={date.toISOString()}>
									<Bilingual hasEn={hasEn}>
										<Fragment slot="es">{formatRailDate(date, "es")}</Fragment>
										{hasEn && <Fragment slot="en">{formatRailDate(date, "en")}</Fragment>}
									</Bilingual>
								</time>
							</span>
							<span class="blog-body">
								<span class="blog-title">
									<Bilingual hasEn={hasEn}>
										<Fragment slot="es">{pair.es?.data.title ?? pair.en?.data.title}</Fragment>
										{hasEn && <Fragment slot="en">{pair.en?.data.title}</Fragment>}
									</Bilingual>
								</span>
								<span class="blog-desc">
									<Bilingual hasEn={hasEn}>
										<Fragment slot="es">{pair.es?.data.description ?? pair.en?.data.description}</Fragment>
										{hasEn && <Fragment slot="en">{pair.en?.data.description}</Fragment>}
									</Bilingual>
								</span>
							</span>
							<span class="blog-arrow" aria-hidden="true">↗</span>
						</a>
					);
				})}
			</div>
		)
	}

	<div class="blog-archive lr">
		<a data-astro-prefetch href={withBase("/posts/")}>
			<T k={archiveCount > 0 ? "blog.viewAll" : "blog.viewBlog"} vars={{ count: archiveCount }} />
		</a>
	</div>
</section>

<style>
	.empty-state {
		border-top: 1px solid var(--hairline);
		padding-top: 2.5rem;
		font-family: var(--font-mono);
		font-size: 0.9rem;
		color: hsl(var(--theme-text-muted));
	}

	.blog-list {
		border-top: 1px solid hsl(var(--theme-text));
	}
	.blog-row {
		display: grid;
		grid-template-columns: 8rem 1fr auto;
		align-items: baseline;
		gap: 1.6rem;
		padding: 1.7rem 0;
		border-bottom: 1px solid var(--hairline);
		text-decoration: none;
		transition: padding 0.4s var(--ease);
	}
	.blog-row:hover {
		padding-left: 1rem;
	}
	.blog-date {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: hsl(var(--theme-text-muted));
		white-space: nowrap;
	}
	.blog-body {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		min-width: 0;
	}
	.blog-title {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: 1.35rem;
		letter-spacing: -0.01em;
		color: hsl(var(--theme-text));
		transition: color 0.25s ease;
	}
	.blog-row:hover .blog-title {
		color: var(--klein);
	}
	.blog-desc {
		color: hsl(var(--theme-text-muted));
		font-size: 0.92rem;
		max-width: 62ch;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.blog-arrow {
		font-family: var(--font-mono);
		color: hsl(var(--theme-text-muted));
		transition: color 0.25s ease, transform 0.25s var(--ease);
	}
	.blog-row:hover .blog-arrow {
		color: var(--klein);
		transform: rotate(45deg);
	}

	.blog-archive {
		margin-top: 2rem;
		font-family: var(--font-mono);
		font-size: 0.85rem;
	}
	.blog-archive a {
		color: hsl(var(--theme-text));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.blog-archive a:hover {
		color: var(--klein);
		text-decoration-color: var(--klein);
	}

	@media (max-width: 640px) {
		.blog-row {
			grid-template-columns: 1fr auto;
			grid-template-areas: "date arrow" "body body";
			row-gap: 0.5rem;
		}
		.blog-date { grid-area: date; }
		.blog-arrow { grid-area: arrow; }
		.blog-body { grid-area: body; }
		.blog-desc { white-space: normal; }
		.blog-row:hover { padding-left: 0; }
	}
</style>
