{/* Scroll-driven behaviour for the homepage sections only: reveal-on-scroll,
    the word-by-word "Sobre mí" quote highlight, animated stat counters, and
    the sticky project-card stack scaling as you scroll past each one. */}
<script>
	const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

	/* ---------- reveal on scroll ---------- */
	const revealIo = new IntersectionObserver(
		(entries) => {
			for (const entry of entries) {
				if (entry.isIntersecting) {
					entry.target.classList.add("in");
					revealIo.unobserve(entry.target);
				}
			}
		},
		{ threshold: 0.15, rootMargin: "0px 0px -6% 0px" },
	);
	document.querySelectorAll(".lr").forEach((el) => revealIo.observe(el));

	/* ---------- "Sobre mí" quote: lights up word by word on scroll ----------
	   Both language variants live in the DOM at once (one hidden via CSS, see
	   global.css), so each is split into words independently — otherwise
	   `textContent` would concatenate both languages into one run. */
	const quote = document.getElementById("about-quote");
	if (quote) {
		const langContainers = [
			...quote.querySelectorAll<HTMLElement>("[data-lang-es], [data-lang-en]"),
		];
		const wordGroups = langContainers.map((container) => {
			const text = container.textContent?.trim() ?? "";
			container.innerHTML = text
				.split(/\s+/)
				.map((w) => `<span class="w">${w}</span>`)
				.join(" ");
			return [...container.querySelectorAll<HTMLElement>(".w")];
		});

		if (reduceMotion) {
			wordGroups.forEach((words) => words.forEach((w) => w.classList.add("lit")));
		} else {
			const onQuoteScroll = () => {
				const card = quote.closest(".about-card") ?? quote;
				const r = card.getBoundingClientRect();
				const progress = Math.min(1, Math.max(0, (innerHeight * 0.85 - r.top) / (r.height * 0.7)));
				wordGroups.forEach((words) => {
					const lit = Math.floor(progress * words.length);
					words.forEach((w, i) => w.classList.toggle("lit", i < lit));
				});
			};
			addEventListener("scroll", onQuoteScroll, { passive: true });
			onQuoteScroll();
		}
	}

	/* ---------- animated stat counters (integers or one-decimal values) ---------- */
	const counterIo = new IntersectionObserver(
		(entries) => {
			for (const entry of entries) {
				if (!entry.isIntersecting) continue;
				const el = entry.target as HTMLElement;
				const end = Number.parseFloat(el.dataset.count ?? "0");
				const decimals = el.dataset.count?.includes(".") ? 1 : 0;
				if (reduceMotion) {
					el.textContent = end.toFixed(decimals);
					counterIo.unobserve(el);
					continue;
				}
				const t0 = performance.now();
				const DURATION = 1200;
				const step = (t: number) => {
					const p = Math.min(1, (t - t0) / DURATION);
					const k = 1 - (1 - p) ** 3;
					el.textContent = (end * k).toFixed(decimals);
					if (p < 1) requestAnimationFrame(step);
				};
				requestAnimationFrame(step);
				counterIo.unobserve(el);
			}
		},
		{ threshold: 0.6 },
	);
	document.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => counterIo.observe(el));

	/* ---------- sticky project cards: scale/blur the one being covered ---------- */
	if (!reduceMotion && matchMedia("(min-width: 961px)").matches) {
		const cards = [...document.querySelectorAll<HTMLElement>(".p-card")];
		if (cards.length > 1) {
			const onStackScroll = () => {
				cards.forEach((card, i) => {
					const next = cards[i + 1];
					if (!next) return;
					const r = card.getBoundingClientRect();
					const n = next.getBoundingClientRect();
					const overlap = Math.min(1, Math.max(0, (r.bottom - n.top) / r.height));
					card.style.transform = `scale(${1 - overlap * 0.06})`;
					card.style.filter = `brightness(${1 - overlap * 0.12}) blur(${overlap * 1.2}px)`;
				});
			};
			addEventListener("scroll", onStackScroll, { passive: true });
			onStackScroll();
		}
	}
</script>
