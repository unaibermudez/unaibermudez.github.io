---
// Eight-spoked asterisk mark (replaces the unicode "✳" glyph used as a
// decorative stamp) — reused by the Hero stamp and the Projects placeholder
// tile. Sizing/color are controlled by the parent via `currentColor` + the
// wrapping element's `width`/`height`.
interface Props {
	class?: string;
}
const { class: className } = Astro.props;
---

<svg class={className} viewBox="0 0 24 24" aria-hidden="true" focusable="false">
	<g stroke="currentColor" stroke-width="2" stroke-linecap="round">
		<line x1="12" y1="2" x2="12" y2="22"></line>
		<line x1="2" y1="12" x2="22" y2="12"></line>
		<line x1="4.5" y1="4.5" x2="19.5" y2="19.5"></line>
		<line x1="19.5" y1="4.5" x2="4.5" y2="19.5"></line>
	</g>
</svg>
