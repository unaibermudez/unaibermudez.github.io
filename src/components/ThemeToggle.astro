---
import { Icon } from "astro-icon/components";
---

<button
	class="theme-toggle"
	id="theme-toggle"
	type="button"
	aria-label="Cambiar tema"
	data-aria-es="Cambiar tema"
	data-aria-en="Toggle theme"
>
	<span class="icon icon-light" aria-hidden="true"><Icon name="feather:moon" /></span>
	<span class="icon icon-dark" aria-hidden="true"><Icon name="feather:sun" /></span>
	<span class="label"></span>
</button>

<style is:global>
	.theme-toggle {
		display: inline-block;
		padding: 6px 12px;
		border-radius: 999px;
		background: hsl(var(--theme-bg) / 0.82);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		color: hsl(var(--theme-text-muted));
		border: 1px solid var(--hairline);
		font-family: var(--font-mono);
		font-size: 11.5px;
		font-weight: 500;
		line-height: 1.4;
		cursor: pointer;
		box-shadow: 0 2px 10px rgba(24, 22, 17, 0.06);
		transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
	}
	.theme-toggle:hover {
		background: hsl(var(--theme-bg));
		border-color: hsl(var(--theme-accent) / 0.5);
		color: hsl(var(--theme-accent));
	}
	.theme-toggle:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
	}

	.theme-toggle .icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 13px;
		height: 13px;
		margin-right: 6px;
		transform: translateY(-1px);
	}
	.theme-toggle .icon svg {
		width: 100%;
		height: 100%;
	}
	.theme-toggle .icon-dark { display: none; }
	[data-theme="dark"] .theme-toggle .icon-light { display: none; }
	[data-theme="dark"] .theme-toggle .icon-dark { display: inline-flex; }

	.theme-toggle .label {
		display: inline-block;
		min-width: 3.6em;
		text-align: left;
	}
	.theme-toggle .label::before { content: "Oscuro"; }
	[data-theme="dark"] .theme-toggle .label::before { content: "Claro"; }
	html[data-lang="en"] .theme-toggle .label::before { content: "Dark"; }
	html[data-lang="en"][data-theme="dark"] .theme-toggle .label::before { content: "Light"; }
</style>

<script>
	const r = document.documentElement;
	const btn = document.getElementById("theme-toggle") as HTMLButtonElement | null;
	if (btn) {
		btn.addEventListener("click", () => {
			const next = r.dataset.theme === "dark" ? "light" : "dark";
			r.dataset.theme = next;
			try { localStorage.setItem("theme", next); } catch {}
			document.dispatchEvent(new CustomEvent("theme-change", { detail: { theme: next } }));
		});
	}
</script>
