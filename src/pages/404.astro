---
import PageLayout from "@/layouts/Base.astro";
import { withBase } from "@/utils/path";
import T from "@/components/T.astro";

const meta = {
	description: "La página que buscabas no existe.",
	title: "404 · No encontrado",
};
---

<PageLayout meta={meta}>
	<section class="not-found">
		<div class="eyebrow">
			<T k="notFound.eyebrow" />
		</div>
		<h1>
			<T k="notFound.title" />
		</h1>
		<p>
			<T k="notFound.bodyStart" /> <a href={withBase("/")}><T k="notFound.home" /></a><T k="notFound.bodyMiddle" />
			<a href={withBase("/posts/")}><T k="notFound.blog" /></a>.
		</p>
	</section>
</PageLayout>

<style>
	.not-found { padding: 24px 0 80px; max-width: 56ch; }
	.eyebrow {
		font-family: var(--font-mono);
		font-size: 11.5px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: hsl(var(--theme-text-muted));
		margin-bottom: 24px;
	}
	.not-found h1 {
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: clamp(32px, 5vw, 44px);
		letter-spacing: -0.02em;
		line-height: 1.12;
		color: hsl(var(--theme-text));
		margin: 0 0 18px;
	}
	.not-found p {
		font-size: 17.5px;
		line-height: 1.7;
		color: hsl(var(--theme-text));
		margin: 0;
	}
	.not-found a {
		color: hsl(var(--theme-accent));
		border-bottom: 1px solid hsl(var(--theme-accent) / 0.4);
		padding-bottom: 1px;
		transition: border-color 0.2s ease;
	}
	.not-found a:hover { border-color: hsl(var(--theme-accent)); }
</style>
