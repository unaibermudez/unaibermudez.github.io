---
import { getEntry, render } from "astro:content";
import PageLayout from "@/layouts/Base.astro";
import Bilingual from "@/components/Bilingual.astro";
import T from "@/components/T.astro";
import { siteConfig } from "@/site-config";
import { absoluteUrl } from "@/utils/path";
import { Schema } from "astro-seo-schema";

const esEntry = await getEntry("page", "es/about");
const enEntry = await getEntry("page", "en/about");
if (!esEntry) throw new Error("Missing src/content/page/es/about.md");
const { Content: EsContent } = await render(esEntry);
const EnContent = enEntry ? (await render(enEntry)).Content : undefined;

const profile = siteConfig.profile;
const authorName = profile?.name ?? siteConfig.author;

// <title>/meta description can't be dual-language in a single document
// head — Spanish is canonical here, same tradeoff as blog post pages.
const meta = {
	description: esEntry.data.description ?? `${authorName} — about me.`,
	title: esEntry.data.title,
};

const personSameAs = [
	profile?.linkedin,
	profile?.github,
	profile?.twitter,
	profile?.mastodon,
].filter((s): s is string => Boolean(s));

const avatarUrl = profile?.avatar ? absoluteUrl(profile.avatar, Astro.site) : undefined;
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "ProfilePage",
		mainEntity: {
			"@type": "Person",
			name: authorName,
			...(avatarUrl ? { image: avatarUrl } : {}),
			...(profile?.jobTitle ? { jobTitle: profile.jobTitle } : {}),
			...(profile?.employer
				? {
						worksFor: {
							"@type": "Organization",
							name: profile.employer,
							...(profile.employerUrl ? { url: profile.employerUrl } : {}),
						},
					}
				: {}),
			...(profile?.alumni
				? {
						alumniOf: {
							"@type": "CollegeOrUniversity",
							name: profile.alumni,
						},
					}
				: {}),
			...(personSameAs.length ? { sameAs: personSameAs } : {}),
		},
	}}
/>

<PageLayout meta={meta}>
	<section class="about" aria-labelledby="about-label">
		<div class="section-label" id="about-label">
			<T k="aboutPage.sectionLabel" />
		</div>
		<div class="bio">
			<Bilingual as="div" hasEn={Boolean(EnContent)}>
				<Fragment slot="es">
					<EsContent />
				</Fragment>
				{EnContent && (
					<Fragment slot="en">
						<EnContent />
					</Fragment>
				)}
			</Bilingual>
		</div>
	</section>
</PageLayout>

<style>
	.about {
		margin-bottom: 64px;
	}
	.bio {
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.75;
		color: hsl(var(--theme-text));
		max-width: var(--reading-width);
	}
	.bio :global(ul) {
		list-style: disc;
		list-style-position: inside;
		margin: 0 0 28px;
		padding: 0;
	}
	.bio :global(ul li) {
		margin-bottom: 6px;
		text-wrap: pretty;
		word-wrap: break-word;
		overflow-wrap: anywhere;
	}
	.bio :global(ul li:last-child) {
		margin-bottom: 0;
	}
	.bio :global(p) {
		margin: 0 0 22px;
		text-wrap: pretty;
	}
	.bio :global(p:last-child) {
		margin-bottom: 0;
	}
	.bio :global(a) {
		color: hsl(var(--theme-text));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.bio :global(a:hover) {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}
	.bio :global(a:focus-visible) {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.bio {
			font-size: 17px;
			line-height: 1.7;
		}
	}
	@media (max-width: 420px) {
		.bio {
			font-size: 16.5px;
		}
	}
</style>
