---
import { getPairDate, getPostPairs, sortPairsByDate, type PostPair } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import Bilingual from "@/components/Bilingual.astro";
import T from "@/components/T.astro";
import { formatRailDate } from "@/utils/date";
import { withBase } from "@/utils/path";
import type { GetStaticPaths, Page } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
	const MAX_POSTS_PER_PAGE = 1000;
	const pairs = sortPairsByDate(await getPostPairs());
	return paginate(pairs, { pageSize: MAX_POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

interface Props {
	page: Page<PostPair>;
}

const { page } = Astro.props;

// Meta description/title can't be dual-language in a single document head —
// kept in Spanish, the site's base language (see BlogPost.astro for the
// same tradeoff on individual post pages).
const meta = {
	description: "Notas y apuntes cortos sobre lo que voy construyendo.",
	title: "Blog",
};

const totalCount = page.total;
const pagefindJsUrl = withBase("/pagefind/pagefind-ui.js");
const pagefindCssUrl = withBase("/pagefind/pagefind-ui.css");
---

<PageLayout meta={meta}>
	<section class="writing" aria-labelledby="writing-label">
		<div class="section-label" id="writing-label">
			<T k="blogArchive.label" /> · {totalCount}{" "}
			<T k={totalCount === 1 ? "blogArchive.entry" : "blogArchive.entries"} />
		</div>

		{
			totalCount > 0 && (
				<>
					<link rel="stylesheet" href={pagefindCssUrl} />
					<div id="pagefind-search" class="pagefind-search" />
				</>
			)
		}

		<div class="timeline">
			{
				page.data.map((pair, idx) => {
					const date = getPairDate(pair);
					const hasEn = Boolean(pair.en);
					return (
						<a
							class="post"
							data-astro-prefetch
							href={withBase(`/posts/${pair.slug}/`)}
							style={`--i: ${idx}`}
						>
							<div class="post-rail">
								<time class="post-date" datetime={date.toISOString()}>
									<Bilingual hasEn={hasEn}>
										<Fragment slot="es">{formatRailDate(date, "es")}</Fragment>
										{hasEn && <Fragment slot="en">{formatRailDate(date, "en")}</Fragment>}
									</Bilingual>
								</time>
								<span class="post-dot" aria-hidden="true" />
							</div>
							<div class="post-body">
								<h2 class="post-title">
									<Bilingual hasEn={hasEn}>
										<Fragment slot="es">{pair.es?.data.title ?? pair.en?.data.title}</Fragment>
										{hasEn && <Fragment slot="en">{pair.en?.data.title}</Fragment>}
									</Bilingual>
								</h2>
								<p class="post-preview">
									<Bilingual hasEn={hasEn}>
										<Fragment slot="es">{pair.es?.data.description ?? pair.en?.data.description}</Fragment>
										{hasEn && <Fragment slot="en">{pair.en?.data.description}</Fragment>}
									</Bilingual>
								</p>
							</div>
						</a>
					);
				})
			}
		</div>
		{
			(page.url.prev || page.url.next) && (
				<nav class="pagination" aria-label="Pagination">
					{page.url.prev && (
						<a class="pag-link prev" data-astro-prefetch href={page.url.prev}>
							<T k="blogArchive.prevPage" />
						</a>
					)}
					{page.url.next && (
						<a class="pag-link next" data-astro-prefetch href={page.url.next}>
							<T k="blogArchive.nextPage" />
						</a>
					)}
				</nav>
			)
		}
	</section>
</PageLayout>

{
	totalCount > 0 && (
		<script define:vars={{ pagefindJsUrl }}>
			// Pagefind's UI bundle is generated post-build (see package.json
			// "postbuild"), so it's loaded as a plain script rather than
			// imported — it doesn't exist yet at Vite build time. In `astro
			// dev` this 404s harmlessly since the index only exists in `dist/`.
			const s = document.createElement("script");
			s.src = pagefindJsUrl;
			s.onload = () => {
				if (window.PagefindUI) {
					const lang = document.documentElement.dataset.lang;
					// eslint-disable-next-line no-new
					new window.PagefindUI({
						element: "#pagefind-search",
						showSubResults: true,
						translations: { placeholder: lang === "en" ? "Search" : "Buscar" },
					});
				}
			};
			document.body.appendChild(s);

			// PagefindUI doesn't expose a live-relocalize API, so just flip the
			// rendered input's placeholder directly when the language toggles.
			document.addEventListener("lang-change", (e) => {
				const input = document.querySelector(".pagefind-ui__search-input");
				if (input) input.placeholder = e.detail.lang === "en" ? "Search" : "Buscar";
			});
		</script>
	)
}

<style>
	.pagefind-search {
		--pagefind-ui-primary: var(--klein);
		--pagefind-ui-text: hsl(var(--theme-text));
		--pagefind-ui-background: hsl(var(--theme-bg));
		--pagefind-ui-border: var(--hairline);
		--pagefind-ui-border-width: 1px;
		--pagefind-ui-border-radius: 8px;
		--pagefind-ui-font: var(--font-sans);
		margin-bottom: 3rem;
	}
</style>

<style>
	.writing {
		margin-bottom: 96px;
	}

	.pagination {
		grid-column: 2;
		margin-top: 8px;
		display: flex;
		gap: 24px;
		align-items: center;
		justify-content: space-between;
	}
	.pag-link {
		display: inline-block;
		padding: 8px 4px;
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: hsl(var(--theme-text-muted));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.pag-link.prev {
		margin-right: auto;
	}
	.pag-link.next {
		margin-left: auto;
	}
	.pag-link:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}
	.pag-link:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.pagination {
			margin-top: 16px;
		}
	}

	@media (max-width: 420px) {
		.writing {
			margin-bottom: 64px;
		}
	}
</style>
