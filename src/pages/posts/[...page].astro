---
import type { CollectionEntry } from "astro:content";
import { getAllPosts, getPostSortDate, sortMDByDate } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { formatRailDate } from "@/utils/date";
import { withBase } from "@/utils/path";
import type { GetStaticPaths, Page } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
	const MAX_POSTS_PER_PAGE = 1000;
	const allPosts = await getAllPosts();
	const allPostsByDate = sortMDByDate(allPosts);
	return paginate(allPostsByDate, { pageSize: MAX_POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

interface Props {
	page: Page<CollectionEntry<"post">>;
}

const { page } = Astro.props;

const meta = {
	description: "Notas y apuntes cortos sobre lo que voy construyendo.",
	title: "Blog",
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: "← Anteriores",
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			text: "Siguientes →",
			url: page.url.next,
		},
	}),
};

const totalCount = page.total;
const pagefindJsUrl = withBase("/pagefind/pagefind-ui.js");
const pagefindCssUrl = withBase("/pagefind/pagefind-ui.css");
---

<PageLayout meta={meta}>
	<section class="writing" aria-labelledby="writing-label">
		<div class="section-label" id="writing-label">Bitácora · {totalCount} {totalCount === 1 ? "entrada" : "entradas"}</div>

		{
			totalCount > 0 && (
				<>
					<link rel="stylesheet" href={pagefindCssUrl} />
					<div id="pagefind-search" class="pagefind-search" />
				</>
			)
		}

		<div class="timeline">
			{
				page.data.map((p, idx) => (
					<a
						class="post"
						data-astro-prefetch
						href={withBase(`/posts/${p.id}/`)}
						style={`--i: ${idx}`}
					>
						<div class="post-rail">
							<time class="post-date" datetime={getPostSortDate(p).toISOString()}>
								{formatRailDate(getPostSortDate(p))}
							</time>
							<span class="post-dot" aria-hidden="true" />
						</div>
						<div class="post-body">
							<h2 class="post-title">{p.data.title}</h2>
							<p class="post-preview">{p.data.description}</p>
						</div>
					</a>
				))
			}
		</div>
		{
			(paginationProps.prevUrl || paginationProps.nextUrl) && (
				<nav class="pagination" aria-label="Pagination">
					{paginationProps.prevUrl && (
						<a class="pag-link prev" data-astro-prefetch href={paginationProps.prevUrl.url}>
							{paginationProps.prevUrl.text}
						</a>
					)}
					{paginationProps.nextUrl && (
						<a class="pag-link next" data-astro-prefetch href={paginationProps.nextUrl.url}>
							{paginationProps.nextUrl.text}
						</a>
					)}
				</nav>
			)
		}
	</section>
</PageLayout>

{
	totalCount > 0 && (
		<script define:vars={{ pagefindJsUrl }}>
			// Pagefind's UI bundle is generated post-build (see package.json
			// "postbuild"), so it's loaded as a plain script rather than
			// imported — it doesn't exist yet at Vite build time. In `astro
			// dev` this 404s harmlessly since the index only exists in `dist/`.
			const s = document.createElement("script");
			s.src = pagefindJsUrl;
			s.onload = () => {
				if (window.PagefindUI) {
					// eslint-disable-next-line no-new
					new window.PagefindUI({ element: "#pagefind-search", showSubResults: true });
				}
			};
			document.body.appendChild(s);
		</script>
	)
}

<style>
	.pagefind-search {
		--pagefind-ui-primary: var(--klein);
		--pagefind-ui-text: hsl(var(--theme-text));
		--pagefind-ui-background: hsl(var(--theme-bg));
		--pagefind-ui-border: var(--hairline);
		--pagefind-ui-border-width: 1px;
		--pagefind-ui-border-radius: 8px;
		--pagefind-ui-font: var(--font-sans);
		margin-bottom: 3rem;
	}
</style>

<style>
	.writing {
		margin-bottom: 96px;
	}

	.pagination {
		grid-column: 2;
		margin-top: 8px;
		display: flex;
		gap: 24px;
		align-items: center;
		justify-content: space-between;
	}
	.pag-link {
		display: inline-block;
		padding: 8px 4px;
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: hsl(var(--theme-text-muted));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.pag-link.prev {
		margin-right: auto;
	}
	.pag-link.next {
		margin-left: auto;
	}
	.pag-link:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}
	.pag-link:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.pagination {
			margin-top: 16px;
		}
	}

	@media (max-width: 420px) {
		.writing {
			margin-bottom: 64px;
		}
	}
</style>
