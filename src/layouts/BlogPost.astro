---
import PostLangBlock from "@/components/blog/PostLangBlock.astro";
import Bilingual from "@/components/Bilingual.astro";
import T from "@/components/T.astro";
import { getPairDate, getPairTags, getPostPairs, type PostPair, sortPairsByDate } from "@/data/post";
import { siteConfig } from "@/site-config";
import { absoluteUrl, withBase } from "@/utils/path";

import BaseLayout from "./Base.astro";
import { Schema } from "astro-seo-schema";

interface Props {
	pair: PostPair;
	esReadingTime: number;
	enReadingTime: number;
}

const { pair, esReadingTime, enReadingTime } = Astro.props;

const hasEn = Boolean(pair.en);

// Publish/updated date, tags and draft status are pair-level metadata — the
// `es/` file is canonical, `en/` is the fallback (see data/post.ts).
const sharedDate = getPairDate(pair);
const tags = getPairTags(pair);
const draft = pair.es?.data.draft ?? pair.en?.data.draft ?? false;
const coverImage = pair.es?.data.coverImage ?? pair.en?.data.coverImage;
const updatedDate = pair.es?.data.updatedDate ?? pair.en?.data.updatedDate;
const ogImageOverride = pair.es?.data.ogImage ?? pair.en?.data.ogImage;

const authorName = siteConfig.profile?.name ?? siteConfig.author;
const postUrl = absoluteUrl(`/posts/${pair.slug}/`, Astro.site);
const socialImage = ogImageOverride ?? `/og-image/${pair.slug}.png`;
const socialImageAbsolute = absoluteUrl(socialImage, Astro.site);
const articleDateIso = (updatedDate ?? sharedDate).toISOString();

// <title>/meta description/Schema can't be dual-language in a single
// document head — Spanish is the site's base language, so it's canonical
// here regardless of which language the visitor has selected client-side.
const metaTitle = pair.es?.data.title ?? pair.en?.data.title ?? "";
const metaDescription = pair.es?.data.description ?? pair.en?.data.description ?? "";

const allPairs = sortPairsByDate(await getPostPairs());
const idx = allPairs.findIndex((p) => p.slug === pair.slug);
const newerPair = idx > 0 ? allPairs[idx - 1] : undefined;
const olderPair = idx >= 0 && idx < allPairs.length - 1 ? allPairs[idx + 1] : undefined;
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "BlogPosting",
		headline: metaTitle,
		datePublished: articleDateIso,
		dateModified: updatedDate?.toISOString(),
		url: postUrl,
		image: socialImageAbsolute,
		author: {
			"@type": "Person",
			name: authorName,
		},
		description: metaDescription,
	}}
/>

<BaseLayout meta={{ articleDate: articleDateIso, description: metaDescription, ogImage: socialImage, title: metaTitle }}>
	<div class="reading-progress" id="reading-progress" aria-hidden="true"></div>
	<div class="post-shell">
		<div class="post-main" data-pagefind-body>
			{pair.es && (
				<Bilingual as="div" hasEn={hasEn}>
					<Fragment slot="es">
						<PostLangBlock
							entry={pair.es}
							tags={tags}
							draft={draft}
							sharedDate={sharedDate}
							updatedDate={updatedDate}
							coverImage={coverImage}
							authorName={authorName}
							dateLocale="es"
							readingTimeMinutes={esReadingTime}
							postUrl={postUrl}
						>
							<slot name="es" />
						</PostLangBlock>
					</Fragment>
					{hasEn && (
						<Fragment slot="en">
							<PostLangBlock
								entry={pair.en!}
								tags={tags}
								draft={draft}
								sharedDate={sharedDate}
								updatedDate={updatedDate}
								coverImage={coverImage}
								authorName={authorName}
								dateLocale="en"
								readingTimeMinutes={enReadingTime}
								postUrl={postUrl}
							>
								<slot name="en" />
							</PostLangBlock>
						</Fragment>
					)}
				</Bilingual>
			)}

			<hr class="rule rule--footer" />

			{(olderPair || newerPair) && (
				<nav class="post-pager" aria-label="More posts">
					{olderPair && (
						<a class="pager-link prev" data-astro-prefetch href={withBase(`/posts/${olderPair.slug}/`)}>
							<span class="pager-eyebrow">
								<T k="blogPost.prev" />
							</span>
							<span class="pager-title">
								<Bilingual hasEn={Boolean(olderPair.en)}>
									<Fragment slot="es">{olderPair.es?.data.title ?? olderPair.en?.data.title}</Fragment>
									{olderPair.en && <Fragment slot="en">{olderPair.en.data.title}</Fragment>}
								</Bilingual>
							</span>
						</a>
					)}
					{newerPair && (
						<a class="pager-link next" data-astro-prefetch href={withBase(`/posts/${newerPair.slug}/`)}>
							<span class="pager-eyebrow">
								<T k="blogPost.next" />
							</span>
							<span class="pager-title">
								<Bilingual hasEn={Boolean(newerPair.en)}>
									<Fragment slot="es">{newerPair.es?.data.title ?? newerPair.en?.data.title}</Fragment>
									{newerPair.en && <Fragment slot="en">{newerPair.en.data.title}</Fragment>}
								</Bilingual>
							</span>
						</a>
					)}
				</nav>
			)}
		</div>
	</div>
</BaseLayout>

<style>
	.post-shell { display: block; position: relative; }

	.reading-progress {
		position: fixed;
		top: 0;
		left: 0;
		height: 2px;
		width: 0;
		background: hsl(var(--theme-accent));
		z-index: 100;
		pointer-events: none;
		transition: width 0.05s linear;
	}

	/* Header/title/byline/tags/cover styles live in PostLangBlock.astro's own
	   <style> — Astro scopes CSS per-file, so rules here would never match
	   elements rendered by that component (this bit us once: the header
	   looked completely unstyled/flat because of it — don't move them back). */

	.rule {
		height: 1px;
		background: var(--hairline);
		border: 0;
		margin: 0 0 44px;
		transition: background-color 0.35s ease;
	}
	/* Extra spacing so stacked footer blocks (post-end link, comments) read as intentional. */
	.rule--footer {
		margin: 56px 0 28px;
	}

	/* Prev/Next post navigation */
	.post-pager {
		display: grid;
		grid-template-columns: 1fr 1fr;
		column-gap: 32px;
		row-gap: 28px;
		margin: 0 0 56px;
		padding: 0 0 0 0;
	}
	.pager-link {
		display: block;
		text-decoration: none;
		min-width: 0;
		transition: transform 0.25s ease;
	}
	.pager-link.next {
		text-align: right;
	}
	.pager-link.prev:hover { transform: translateX(-2px); }
	.pager-link.next:hover { transform: translateX(2px); }
	.pager-eyebrow {
		display: block;
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: hsl(var(--theme-text) / 0.72);
		margin-bottom: 8px;
	}
	.pager-link.prev .pager-eyebrow::before { content: "← "; }
	.pager-link.next .pager-eyebrow::after { content: " →"; }
	.pager-title {
		display: block;
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.3;
		font-weight: 500;
		letter-spacing: -0.01em;
		color: hsl(var(--theme-text));
		text-wrap: balance;
		word-wrap: break-word;
		overflow-wrap: anywhere;
		transition: color 0.2s ease;
	}
	.pager-link:hover .pager-title {
		color: hsl(var(--theme-accent));
	}
	/* Lone prev/next spans full width, text on its natural side. */
	.post-pager:has(.pager-link.prev:only-child) .pager-link.prev,
	.post-pager:has(.pager-link.next:only-child) .pager-link.next {
		grid-column: 1 / -1;
	}
	@media (max-width: 720px) {
		.post-pager {
			grid-template-columns: 1fr;
			row-gap: 22px;
			margin-bottom: 40px;
		}
		.pager-link.next {
			order: 0;
			text-align: left;
		}
		.pager-link.prev {
			order: 1;
		}
	}

	@media (max-width: 720px) {
		.post-title { font-size: 30px; line-height: 1.15; }
		.byline { font-size: 15.5px; }
		.rule { margin-bottom: 32px; }
	}
	@media (max-width: 420px) {
		.post-eyebrow { font-size: 11px; margin-bottom: 18px; }
		.post-eyebrow .sep { margin: 0 6px; }
		.post-title { font-size: 26px; }
		.byline { font-size: 14.5px; margin-bottom: 24px; }
		.rule { margin-bottom: 26px; }
		.post-end { font-size: 14px; }
	}

	.post-end a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}
</style>

<style is:global>
	.post-article {
		font-family: var(--font-serif);
		color: hsl(var(--theme-text));
	}

	.post-article > p {
		font-size: 17.5px;
		line-height: 1.75;
		color: hsl(var(--theme-text));
		margin: 0 0 24px;
		max-width: var(--reading-width);
		word-wrap: break-word;
		overflow-wrap: anywhere;
	}
	.post-article > p:first-of-type::first-letter {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 500;
		color: hsl(var(--theme-accent));
		float: left;
		font-size: 3.6em;
		line-height: 0.92;
		padding: 4px 10px 0 0;
		margin-top: 4px;
	}
	.post-article p em,
	.post-article em {
		font-style: italic;
	}
	.post-article p strong,
	.post-article strong {
		font-weight: 500;
		color: hsl(var(--theme-text));
	}

	.post-article h2 {
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: 27px;
		line-height: 1.22;
		letter-spacing: -0.014em;
		color: hsl(var(--theme-text));
		margin: 56px 0 20px;
		word-wrap: break-word;
		overflow-wrap: anywhere;
	}
	.post-article h3 {
		font-family: var(--font-serif);
		font-weight: 500;
		font-style: italic;
		font-size: 20px;
		line-height: 1.3;
		letter-spacing: -0.005em;
		color: hsl(var(--theme-text));
		margin: 38px 0 14px;
		word-wrap: break-word;
		overflow-wrap: anywhere;
	}
	.post-article h4 {
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: 17.5px;
		line-height: 1.35;
		color: hsl(var(--theme-text));
		margin: 30px 0 12px;
	}

	.post-article a {
		color: hsl(var(--theme-text));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		word-break: break-word;
		overflow-wrap: anywhere;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.post-article a:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}

	.post-article :not(pre) > code {
		font-family: var(--font-mono);
		font-size: 14.5px;
		background: var(--paper);
		border: 1px solid var(--hairline);
		padding: 1px 6px;
		border-radius: 3px;
		color: hsl(var(--theme-text-muted));
		font-variant-numeric: tabular-nums;
		font-feature-settings: "tnum";
		transition: background-color 0.35s ease, border-color 0.35s ease;
	}

	.post-article pre {
		background: var(--paper);
		border: 1px solid var(--hairline);
		border-radius: 4px;
		padding: 16px;
		margin: 28px 0;
		overflow-x: auto;
		max-width: 100%;
		font-size: 14px;
		line-height: 1.7;
		transition: background-color 0.35s ease, border-color 0.35s ease;
	}
	.post-article pre code {
		background: transparent;
		border: 0;
		padding: 0;
		font-size: inherit;
		color: inherit;
	}
	/* expressive-code wrapper safety */
	.post-article .expressive-code {
		margin: 28px 0;
	}

	.post-article ul {
		margin: 0 0 28px;
		padding: 0;
		list-style: none;
		max-width: var(--reading-width);
	}
	.post-article ul li {
		position: relative;
		padding-left: 22px;
		font-size: 17.5px;
		line-height: 1.7;
		color: hsl(var(--theme-text));
		margin-bottom: 10px;
		word-wrap: break-word;
		overflow-wrap: anywhere;
	}
	.post-article ul li::before {
		content: "";
		position: absolute;
		left: 4px;
		top: 0.78em;
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: hsl(var(--theme-accent));
	}
	.post-article ul ul {
		margin: 10px 0 4px;
	}
	.post-article ul ul li {
		font-size: 17px;
		color: hsl(var(--theme-text-muted));
		margin-bottom: 6px;
	}
	.post-article ul ul li::before {
		background: transparent;
		border: 1px solid hsl(var(--theme-accent));
		width: 5px;
		height: 5px;
	}

	.post-article ol {
		margin: 0 0 28px;
		padding-left: 22px;
		max-width: var(--reading-width);
	}
	.post-article ol li {
		font-size: 17.5px;
		line-height: 1.7;
		color: hsl(var(--theme-text));
		margin-bottom: 10px;
		padding-left: 6px;
	}
	.post-article ol li::marker {
		color: hsl(var(--theme-accent));
		font-family: var(--font-mono);
		font-size: 14px;
	}

	.post-article li > p {
		margin: 0;
		display: inline;
	}

	.post-article blockquote {
		margin: 28px 0;
		padding: 4px 0 4px 22px;
		border-left: 2px solid hsl(var(--theme-accent));
		font-style: italic;
		color: hsl(var(--theme-text-muted));
		font-size: 18px;
		line-height: 1.65;
		max-width: var(--reading-width);
	}
	.post-article blockquote p {
		margin: 0 0 12px;
		font-size: inherit;
		max-width: none;
	}
	.post-article blockquote p:last-child {
		margin-bottom: 0;
	}
	.post-article blockquote p:first-of-type::first-letter {
		all: unset;
	}

	/* Predictable sizing prevents CLS */
	.post-article figure {
		margin: 36px 0;
		padding: 0;
	}
	.post-article figure video,
	.post-article video {
		display: block;
		width: 100%;
		height: auto;
		border: 1px solid var(--hairline);
		background: var(--paper);
		transition: border-color 0.35s ease;
	}
	.post-article img {
		display: block;
		max-width: 100%;
		height: auto;
		border: 1px solid var(--hairline);
		background: var(--paper);
	}
	@media (prefers-reduced-motion: no-preference) {
		.post-article img[loading="lazy"]:not([data-in]) {
			opacity: 0;
		}
		.post-article img[loading="lazy"][data-in] {
			opacity: 1;
			transition: opacity 360ms ease;
		}
	}

	.post-article h2,
	.post-article h3 {
		position: relative;
	}
	.post-article .heading-anchor {
		position: absolute;
		left: -1.25em;
		top: 0;
		bottom: 0;
		display: inline-flex;
		align-items: center;
		font-family: var(--font-mono);
		font-size: 0.7em;
		color: hsl(var(--theme-accent));
		opacity: 0;
		transition: opacity 0.18s ease;
		text-decoration: none;
		padding: 0 0.4em;
		background: transparent;
		border: 0;
		cursor: pointer;
	}
	@media (hover: hover) {
		.post-article h2:hover .heading-anchor,
		.post-article h3:hover .heading-anchor,
		.post-article .heading-anchor:focus-visible {
			opacity: 1;
		}
	}
	@media (hover: none) {
		.post-article .heading-anchor {
			opacity: 0.35;
			position: static;
			margin-left: 0.4em;
		}
	}
	@media (max-width: 720px) {
		.post-article .heading-anchor {
			position: static;
			margin-left: 0.4em;
			opacity: 0.35;
		}
	}
	.post-article figure img {
		width: 100%;
	}
	.post-article figcaption {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: 14.5px;
		color: hsl(var(--theme-text) / 0.72);
		margin-top: 12px;
		line-height: 1.5;
	}
	.post-article figcaption .label {
		font-family: var(--font-mono);
		font-style: normal;
		font-size: 11px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: hsl(var(--theme-text-muted));
		margin-right: 8px;
	}

	.post-article table {
		width: 100%;
		max-width: 100%;
		border-collapse: collapse;
		margin: 28px 0;
		font-size: 15.5px;
		font-family: var(--font-sans);
	}
	.post-article th,
	.post-article td {
		text-align: left;
		padding: 8px 12px;
		border-bottom: 1px solid var(--hairline);
	}
	.post-article th {
		font-weight: 500;
		color: hsl(var(--theme-text));
	}

	.post-article hr {
		border: 0;
		height: 1px;
		background: var(--hairline);
		margin: 40px 0;
	}

	@media (max-width: 720px) {
		.post-article > p,
		.post-article ul li,
		.post-article ol li {
			font-size: 17px;
			line-height: 1.72;
		}
		.post-article h2 { font-size: 23px; margin: 44px 0 16px; }
		.post-article h3 { font-size: 18.5px; margin: 30px 0 12px; }
		.post-article :not(pre) > code { font-size: 13.5px; }
		.post-article figure { margin: 28px 0; }
	}
	@media (max-width: 420px) {
		.post-article > p,
		.post-article ul li,
		.post-article ol li {
			font-size: 16px;
			line-height: 1.7;
		}
		.post-article h2 { font-size: 20px; margin: 36px 0 14px; }
		.post-article h3 { font-size: 17px; margin: 26px 0 10px; }
		.post-article ul { padding-left: 0; }
		.post-article ul li { padding-left: 18px; }
		.post-article blockquote { padding-left: 16px; font-size: 16.5px; }
		.post-article figcaption { font-size: 13.5px; }
	}

	.post-article a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}
</style>

<script>
	const progressBar = document.getElementById("reading-progress") as HTMLElement | null;
	if (progressBar) {
		const update = () => {
			const h = document.documentElement;
			const max = h.scrollHeight - h.clientHeight;
			const pct = max > 0 ? Math.min(100, (h.scrollTop / max) * 100) : 0;
			progressBar.style.width = pct + "%";
		};
		update();
		window.addEventListener("scroll", update, { passive: true });
		window.addEventListener("resize", update, { passive: true });
	}

	const lazyImgs = document.querySelectorAll<HTMLImageElement>(
		'.post-article img[loading="lazy"]',
	);
	if (lazyImgs.length && "IntersectionObserver" in window) {
		const io = new IntersectionObserver(
			(entries) => {
				entries.forEach((e) => {
					if (e.isIntersecting) {
						(e.target as HTMLElement).dataset.in = "1";
						io.unobserve(e.target);
					}
				});
			},
			{ rootMargin: "120px 0px" },
		);
		lazyImgs.forEach((img) => io.observe(img));
	}

	const slugify = (s: string) =>
		s.toLowerCase().trim().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
	const usedIds = new Set<string>();
	document
		.querySelectorAll<HTMLHeadingElement>(".post-article h2, .post-article h3")
		.forEach((h) => {
			const baseId = h.id || slugify(h.textContent ?? "");
			if (!baseId) return;
			let id = baseId;
			for (let n = 2; usedIds.has(id); n++) id = `${baseId}-${n}`;
			usedIds.add(id);
			if (!h.id) h.id = id;

			const btn = document.createElement("button");
			btn.type = "button";
			btn.className = "heading-anchor";
			btn.setAttribute("aria-label", `Copiar enlace a ${h.textContent ?? "esta sección"}`);
			btn.textContent = "#";
			btn.addEventListener("click", async () => {
				const url = `${location.origin}${location.pathname}#${id}`;
				try {
					await navigator.clipboard.writeText(url);
					btn.textContent = "✓";
					setTimeout(() => (btn.textContent = "#"), 1200);
				} catch {}
			});
			h.prepend(btn);
		});
</script>
