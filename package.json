{
	"name": "personal-web",
	"version": "0.1.0",
	"description": "Portfolio personal de Unai Bermúdez — Full Stack Developer. Basado en Astro Sienna.",
	"license": "MIT",
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "astro check && astro build",
		"postbuild": "pagefind --site dist",
		"preview": "astro preview",
		"lint": "biome lint .",
		"format": "npm run format:code && npm run format:imports",
		"format:code": "biome format . --write && prettier -w \"**/*\" \"!**/*.{md,mdx}\" --ignore-unknown --cache",
		"format:imports": "biome check --formatter-enabled=false --write",
		"check": "astro check"
	},
	"dependencies": {
		"@astrojs/mdx": "5.0.4",
		"@astrojs/rss": "4.0.18",
		"@astrojs/sitemap": "3.7.2",
		"@astrojs/tailwind": "6.0.2",
		"@fontsource/fragment-mono": "^5.2.8",
		"@fontsource/fraunces": "^5.2.9",
		"@fontsource/hanken-grotesk": "^5.2.8",
		"@playform/compress": "^0.2.3",
		"astro": "6.3.1",
		"astro-expressive-code": "^0.41.7",
		"astro-icon": "^1.1.5",
		"astro-robots-txt": "^1.0.0",
		"astro-seo-schema": "^5.2.0",
		"astro-webmanifest": "^1.0.0",
		"cssnano": "^7.1.9",
		"hastscript": "^9.0.1",
		"katex": "^0.16.45",
		"mdast-util-directive": "^3.1.0",
		"mdast-util-to-markdown": "^2.1.2",
		"mdast-util-to-string": "^4.0.0",
		"rehype-external-links": "^3.0.0",
		"rehype-katex": "^7.0.1",
		"remark-directive": "^4.0.0",
		"remark-math": "^6.0.0",
		"satori": "0.15.2",
		"satori-html": "^0.3.2",
		"schema-dts": "^1.1.5",
		"sharp": "^0.34.5",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@biomejs/biome": "^2.4.15",
		"@iconify-json/mdi": "^1.2.3",
		"@resvg/resvg-js": "^2.6.2",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"autoprefixer": "^10.5.0",
		"pagefind": "^1.5.2",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"reading-time": "^1.5.0",
		"rehype-unwrap-images": "^1.0.0",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.9.3"
	}
}
